{
  "manifest_version": 3,
  "name": "Screen Recorder · QA mode",
  "version": "2.0.0",
  "description": "Record your screen, window or tab. QA mode: console, network (HAR), steps and a bug report synced with the video.",
  "permissions": [
    "desktopCapture",
    "tabCapture",
    "activeTab",
    "offscreen",
    "downloads",
    "storage",
    "scripting"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Record screen",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Start or stop the recording"
    },
    "add-marker": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Add a bug marker to the recording"
    },
    "toggle-annotate": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Draw over the recorded tab (annotation)"
    }
  }
}